# AVD Masters Suite — Example Configuration
# Copy to config.yaml and fill in your values.
#
# SECURITY: config.yaml contains credentials — protect it:
#   chmod 600 config.yaml
#   Add config.yaml to .gitignore (already done in the repo default)
#
# Environment variable substitution: any string value can reference an
# environment variable using ${VAR_NAME} syntax. The process will refuse
# to start if a referenced variable is not set. Example:
#   winrm_password: "${RDS_PASSWORD}"
#   webhook_url: "${TEAMS_WEBHOOK_URL}"

# Global poll interval in seconds (can be overridden per platform)
poll_interval_s: 60

# Logging: DEBUG | INFO | WARNING | ERROR
log_level: INFO

# ── Alert thresholds (optional — these are the defaults) ──────────────────
thresholds:
  avd_host_cpu_warn: 75.0
  avd_host_cpu_crit: 90.0
  avd_host_mem_warn: 85.0
  avd_host_mem_crit: 95.0
  rds_host_cpu_warn: 75.0
  rds_host_cpu_crit: 90.0
  rds_host_mem_warn: 85.0
  rds_host_mem_crit: 95.0
  rds_license_warn: 80.0     # % CAL utilization
  rds_license_crit: 95.0
  citrix_unregistered_warn: 1  # unregistered VDAs per delivery group
  citrix_unregistered_crit: 3

# ── Best-practice analysis (optional) ─────────────────────────────────────
# Tunes the `python -m vdm --analyze` health report. Every key shown is the
# built-in default — uncomment only what you want to override. Each platform
# block is passed straight to its analyser, so any threshold defined in
# vdm/analysis/<platform>.py _DEFAULTS can be set here.
#
# analysis:
#   avd:
#     min_hosts_per_pool:        2     # HA floor per host pool
#     disk_warn_pct:            80.0   # session-host C:/FSLogix disk pressure
#     disk_crit_pct:            90.0
#     heartbeat_stale_minutes:  15     # flag hosts whose agent has gone silent
#     max_os_builds_per_pool:    1     # >1 distinct OS build = image drift
#     disconnected_ratio_warn:  0.30   # disconnected/total session ratio
#   rds:
#     min_brokers:               2     # Connection Broker HA floor
#     max_uptime_days:          30.0   # patch-hygiene reboot reminder
#     idle_disconnect_minutes:  240    # disconnected sessions idle this long...
#     idle_session_warn_count:   5     # ...and at least this many → warn
#   citrix:
#     min_controllers:           2     # Delivery Controller HA floor
#     session_per_vda_warn:      8     # avg active sessions per registered VDA
#     session_per_vda_crit:     12
#     disconnected_ratio_warn:  0.30
#   gpu:
#     fb_saturated_pct:         88.0   # vGPU framebuffer too small (undersized)
#     fb_underused_pct:         20.0   # vGPU framebuffer oversized (wasted licence)
#     sm_q_profile_min_pct:     15.0   # Q-profile users below this → B would do

# ── Prometheus exporter (optional) ────────────────────────────────────────
# Exposes /metrics for Prometheus scraping.
# Run with: python -m avd_masters --exporter-only
# Or alongside the TUI/headless mode by just adding this block.
#
# prometheus:
#   port: 9090
#   host: 0.0.0.0
#   include_sessions: false  # true adds per-session labels (high cardinality)

# ── Notifiers ──────────────────────────────────────────────────────────────
notifiers:
  # Always-on console notifier (color-coded alerts in terminal)
  console: {}

  # Optional: MS Teams incoming webhook
  # Store the URL in an env var — never commit it to source control.
  # teams:
  #   webhook_url: "${TEAMS_WEBHOOK_URL}"

# ── Azure Virtual Desktop ──────────────────────────────────────────────────
# Credentials via DefaultAzureCredential:
#   - Set AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID env vars
#     for a service principal, OR
#   - Run `az login` for interactive auth
avd:
  subscription_id: "00000000-0000-0000-0000-000000000000"

  # Optional: limit to specific resource groups (omit to scan all)
  # resource_groups:
  #   - rg-avd-prod
  #   - rg-avd-dev

  poll_interval_s: 60

# ── On-Premises Terminal Services (RDS) ───────────────────────────────────
rds:
  farm_name: "Production RDS Farm"

  # All session hosts AND brokers
  hosts:
    - rdsh01.corp.local
    - rdsh02.corp.local
    - rdsh03.corp.local
    - rdbroker01.corp.local

  # Subset of hosts that are RD Connection Brokers
  broker_hosts:
    - rdbroker01.corp.local

  # Optional RD Licensing server
  # license_server: rdlicense01.corp.local

  winrm_username: "CORP\\svc-monitoring"
  winrm_password: "${RDS_PASSWORD}"      # set RDS_PASSWORD env var
  winrm_transport: ntlm   # ntlm | kerberos — do NOT use basic without SSL
  winrm_port: 5986         # 5986 = HTTPS (default), 5985 = HTTP (insecure)
  use_ssl: true            # default true — set false only for lab/testing

  poll_interval_s: 60

# ── Citrix VDI ─────────────────────────────────────────────────────────────
citrix:
  site_name: "Production Citrix Site"

  # Option A: Citrix Director OData API (recommended)
  director_url: "https://citrix-director.corp.local/Director"
  username: "CORP\\svc-monitoring"
  password: "${CITRIX_PASSWORD}"    # set CITRIX_PASSWORD env var
  auth_transport: ntlm    # ntlm | basic — do NOT use basic without TLS
  verify_ssl: true         # never set false in production

  # Option B: WinRM + PowerShell Broker SDK (set use_winrm: true)
  # use_winrm: true
  # winrm_host: ddc01.corp.local
  # winrm_username: "CORP\\svc-monitoring"
  # winrm_password: "CHANGE_ME"
  # winrm_transport: ntlm

  poll_interval_s: 60
