# AVD Masters — Environment Configuration
# Professional defaults with clear enterprise options.

# Azure (optional — blank uses DefaultAzureCredential / az login)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Scope
AZURE_RESOURCE_GROUP=
AZURE_HOSTPOOL_NAME=

# Storage
DB_PATH=./tesla.db

# Polling
POLL_INTERVAL_SECONDS=60

# Connection defaults
DEFAULT_CONN_METHOD=winrm
DEFAULT_WINRM_USERNAME=
DEFAULT_WINRM_PASSWORD=
DEFAULT_WINRM_PORT=5985

DEFAULT_SSH_USERNAME=
DEFAULT_SSH_KEY_PATH=
DEFAULT_SSH_PORT=22

# Thresholds (same excellent defaults)
GPU_UTIL_WARN_PCT=75
GPU_UTIL_CRIT_PCT=90
MEM_USED_WARN_PCT=85
MEM_USED_CRIT_PCT=95
IMBALANCE_WARN_THRESHOLD=0.30
IMBALANCE_CRIT_THRESHOLD=0.50

# Email Alerting (optional — disabled by default)
AVD_ALERT_EMAIL_ENABLED=false
AVD_ALERT_SMTP_HOST=
AVD_ALERT_SMTP_PORT=587
AVD_ALERT_SMTP_USER=
AVD_ALERT_SMTP_PASS=
AVD_ALERT_FROM=avd-masters@yourcompany.com
AVD_ALERT_TO=alerts@yourcompany.com

# Note: For CMMC 2.0 and governance configuration, see governance.py documentation.
